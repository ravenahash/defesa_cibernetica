import hashlib

def calcular_hash_arquivo(caminho_arquivo, algoritmo='sha256'):
    hash_func = hashlib.new(algoritmo)
    with open(caminho_arquivo, 'rb') as f:
        while chunk := f.read(8192):
            hash_func.update(chunk)
    return hash_func.hexdigest()

def verificar_colisao(caminho_arquivo1, caminho_arquivo2):
    algoritmos = ['md5', 'sha1', 'sha224', 'sha256', 'sha384', 'sha512']
    resultados = {}
    for algo in algoritmos:
        hash1 = calcular_hash_arquivo(caminho_arquivo1, algo)
        hash2 = calcular_hash_arquivo(caminho_arquivo2, algo)
        resultados[algo] = (hash1, hash2, hash1 == hash2)
    return resultados

