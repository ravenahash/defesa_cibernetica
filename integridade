# MD5 hash value of a file
import hashlib

filename = "ship.jpeg"
with open(filename,"rb") as f:
    bytes = f.read() # read file as bytes
    readable_hash = hashlib.md5(bytes).hexdigest();
    print(f"MD5 hash of {filename}: {readable_hash}")


